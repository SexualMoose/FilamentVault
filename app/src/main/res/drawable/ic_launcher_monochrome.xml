<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon monochrome layer for Android 13+ themed icons (Material You).
    System tints this automatically to match the user's wallpaper palette, so
    we render everything in pure white and let Android handle color.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer flange silhouette (slightly translucent to suggest the disc) -->
    <path
        android:pathData="M54,26 A28,28 0 1,0 54,82 A28,28 0 1,0 54,26 Z"
        android:fillColor="#FFFFFFFF"
        android:fillAlpha="0.45" />

    <!-- Filament coil — solid ring -->
    <path
        android:pathData="M54,32 A22,22 0 1,0 54,76 A22,22 0 1,0 54,32 Z M54,44 A10,10 0 1,1 54,64 A10,10 0 1,1 54,44 Z"
        android:fillType="evenOdd"
        android:fillColor="#FFFFFFFF" />

</vector>
